      <aliases enabled='yes' />
      <column caption='Delivery performance' datatype='string' name='[Calculation_0407696550694912]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [On-Time Delivery Rate] &gt;= 93 THEN &quot;Good&quot;&#13;&#10;ELSEIF [On-Time Delivery Rate] &gt;= 90 THEN &quot;Average&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='Selected KPI' datatype='integer' name='[Calculation_0407696554053633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Inventory Level&quot; THEN [Inventory Level]&#13;&#10;WHEN &quot;Shipping Cost&quot; THEN [Shipping Cost]&#13;&#10;WHEN &quot;On-Time Delivery&quot; THEN [On-Time Delivery Rate]&#13;&#10;END' />
      </column>
      <column caption='Dynamic KPI' datatype='real' name='[Calculation_0407696556269570]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Inventory Level&quot; THEN SUM([Inventory Level])&#13;&#10;WHEN &quot;Shipping Cost&quot; THEN SUM([Shipping Cost])&#13;&#10;WHEN &quot;On-Time Delivery&quot; THEN AVG([On-Time Delivery Rate])&#13;&#10;END' />
      </column>
      <column caption='KPI Label' datatype='string' name='[Calculation_0407696556482563]' role='measure' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Inventory Level&quot; THEN&#13;&#10;    IF SUM([Inventory Level]) &gt;= 1000 THEN&#13;&#10;        STR(INT(SUM([Inventory Level])/1000)) + &quot;K&quot;&#13;&#10;    ELSE&#13;&#10;        STR(SUM([Inventory Level]))&#13;&#10;    END&#13;&#10;WHEN &quot;Shipping Cost&quot; THEN&#13;&#10;    &quot;₹&quot; + STR(SUM([Shipping Cost]))&#13;&#10;WHEN &quot;On-Time Delivery&quot; THEN&#13;&#10;    STR(ROUND(AVG([On-Time Delivery Rate])*100,1)) + &quot;%&quot;&#13;&#10;END' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='integer' name='[Order ID]' role='dimension' type='ordinal' />
      <column datatype='string' name='[Region]' role='dimension' type='nominal' />
      <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
