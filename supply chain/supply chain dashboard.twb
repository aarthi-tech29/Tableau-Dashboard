    <worksheet name='Dynamic KPI Selector Chart'>
      <table>
        <view>
          <datasources>
            <datasource caption='Supply_Chain_Dashboard_Data (Supply_Chain_Dashboard_Data)' name='federated.1df2hsa17ybov31b7nqao0x2senm' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='KPI Selector' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Inventory Level&quot;'>
              <calculation class='tableau' formula='&quot;Inventory Level&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1df2hsa17ybov31b7nqao0x2senm'>
            <column caption='Dynamic KPI' datatype='real' name='[Calculation_0407696556269570]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Inventory Level&quot; THEN SUM([Inventory Level])&#13;&#10;WHEN &quot;Shipping Cost&quot; THEN SUM([Shipping Cost])&#13;&#10;WHEN &quot;On-Time Delivery&quot; THEN AVG([On-Time Delivery Rate])&#13;&#10;END' />
            </column>
            <column caption='KPI Label' datatype='string' name='[Calculation_0407696556482563]' role='measure' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Inventory Level&quot; THEN&#13;&#10;    IF SUM([Inventory Level]) &gt;= 1000 THEN&#13;&#10;        STR(INT(SUM([Inventory Level])/1000)) + &quot;K&quot;&#13;&#10;    ELSE&#13;&#10;        STR(SUM([Inventory Level]))&#13;&#10;    END&#13;&#10;WHEN &quot;Shipping Cost&quot; THEN&#13;&#10;    &quot;₹&quot; + STR(SUM([Shipping Cost]))&#13;&#10;WHEN &quot;On-Time Delivery&quot; THEN&#13;&#10;    STR(ROUND(AVG([On-Time Delivery Rate])*100,1)) + &quot;%&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='integer' name='[Inventory Level]' role='measure' type='quantitative' />
            <column datatype='integer' name='[On-Time Delivery Rate]' role='measure' type='quantitative' />
            <column datatype='string' name='[Product]' role='dimension' type='nominal' />
            <column datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Shipping Cost]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='string' name='[Supplier]' role='dimension' type='nominal' />
            <column-instance column='[Country]' derivation='None' name='[none:Country:nk]' pivot='key' type='nominal' />
            <column-instance column='[Product]' derivation='None' name='[none:Product:nk]' pivot='key' type='nominal' />
            <column-instance column='[Region]' derivation='None' name='[none:Region:nk]' pivot='key' type='nominal' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
            <column-instance column='[Supplier]' derivation='None' name='[none:Supplier:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0407696556269570]' derivation='User' name='[usr:Calculation_0407696556269570:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0407696556482563]' derivation='User' name='[usr:Calculation_0407696556482563:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
